@startuml
' ── Tối ưu bố cục để tránh rối mắt ──
left to right direction
skinparam actorStyle awesome
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam wrapWidth 120


' ── ACTORS (Sắp xếp phân tầng) ──
actor "Nhân viên" as Employee
actor "Trưởng phòng" as Manager
actor "Quản trị viên" as Admin

Employee <|-- Manager
Manager  <|-- Admin

' ── HỆ THỐNG ──
rectangle "Hệ thống Quản lý Nhân sự (HRMS)" {

    ' Nhóm chức năng cá nhân & chung
    package "Tài khoản & Tiện ích" {
        usecase "UC1: Đăng nhập" as UC1
        usecase "UC2: Đăng xuất" as UC2
        usecase "UC3: Xem hồ sơ" as UC3
        usecase "UC4: Đổi mật khẩu" as UC4
        usecase "UC5: Xem thông báo" as UC5
        usecase "UC6: Xem lương" as UC6
    }

    ' Nhóm nghiệp vụ hàng ngày
    package "Quản lý Công việc & Chấm công" {
        usecase "UC7: Chấm công" as UC7
        usecase "UC8: Lịch sử công" as UC8
        usecase "UC11: Xem Task" as UC11
        usecase "UC12: Cập nhật Task" as UC12

        usecase "Định vị GPS" as GPS
        usecase "Tính phút muộn" as Late
    }

    ' Nhóm Đơn từ
    package "Quản lý Đơn yêu cầu" {
        usecase "UC9: Gửi đơn" as UC9
        usecase "UC10: Theo dõi đơn" as UC10
        usecase "UC15: Phê duyệt đơn" as UC15
    }

    ' Nhóm Quản lý (Manager/Admin)
    package "Quản trị & Báo cáo" {
        usecase "UC13: Quản lý NV" as UC13
        usecase "UC14: Bảng công PB" as UC14
        usecase "UC16: Giao Task" as UC16
        usecase "UC17: Dashb. Phòng" as UC17
        usecase "UC18: Quản lý User" as UC18
        usecase "UC19: Quản lý PB" as UC19
        usecase "UC20: Bảng công CTy" as UC20
        usecase "UC21: Dashb. Hệ thống" as UC21
        usecase "UC22: Tính lương" as UC22
        usecase "UC23: Cài đặt" as UC23
    }
}

' ── KẾT NỐI (Gom nhóm để giảm đường kẻ) ──

' Employee kết nối tới các nhóm cơ bản
Employee --> UC1
Employee --> UC2
Employee --> UC3
Employee --> UC4
Employee --> UC5
Employee --> UC6
Employee --> UC7
Employee --> UC8
Employee --> UC9
Employee --> UC10
Employee --> UC11
Employee --> UC12

' Manager kết nối trực tiếp tới cụm quản lý
Manager --> UC13
Manager --> UC14
Manager --> UC15
Manager --> UC16
Manager --> UC17

' Admin kết nối trực tiếp tới cụm hệ thống
Admin --> UC18
Admin --> UC19
Admin --> UC20
Admin --> UC21
Admin --> UC22
Admin --> UC23

' ── QUAN HỆ ĐẶC BIỆT ──
UC7 ..> GPS : <<include>>
UC7 ..> Late : <<include>>
UC15 ..> UC10 : <<extend>>
UC22 ..> UC14 : <<include>>
UC22 ..> UC12 : <<include>>

@enduml